@page "/admin/users"
@using RVM.AuthForge.Domain.Entities
@using Microsoft.AspNetCore.Identity
@using Microsoft.EntityFrameworkCore
@inject UserManager<ApplicationUser> UserManager
@inject NavigationManager Nav

<h1>Users</h1>

@if (!string.IsNullOrEmpty(_message))
{
    <div class="alert @(_isError ? "alert-danger" : "alert-success")">@_message</div>
}

<h2>Create User</h2>
<div class="add-form">
    <input @bind="_newEmail" placeholder="Email" class="input-sm" />
    <input @bind="_newFullName" placeholder="Full Name" class="input-sm" />
    <input @bind="_newPassword" type="password" placeholder="Password" class="input-sm" />
    <input @bind="_newRole" placeholder="Role (optional)" class="input-sm" style="width:120px" />
    <button class="btn-sm btn-primary" @onclick="CreateUser">Create</button>
</div>

<h2>User List</h2>
<div class="search-bar">
    <input @bind="_search" @bind:event="oninput" placeholder="Search by name or email..." class="input-search" />
    <button class="btn-sm" @onclick="() => LoadPage(1)">Search</button>
</div>

<table class="data-table">
    <thead><tr><th>Name</th><th>Email</th><th>Active</th><th>Email Confirmed</th><th>2FA</th><th>Created</th><th>Actions</th></tr></thead>
    <tbody>
        @foreach (var user in _users)
        {
            <tr>
                <td>@user.FullName</td>
                <td>@user.Email</td>
                <td><span class="@(user.Active ? "status-active" : "status-inactive")">@(user.Active ? "Yes" : "No")</span></td>
                <td>@(user.EmailConfirmed ? "Yes" : "No")</td>
                <td>@(user.TwoFactorEnabled ? "Yes" : "No")</td>
                <td>@user.CreatedAt.ToString("d")</td>
                <td>
                    <button class="btn-sm" @onclick="() => GoToUser(user.Id)">Details</button>
                    @if (user.LockoutEnd > DateTimeOffset.UtcNow)
                    {
                        <button class="btn-sm btn-success" @onclick="() => Unlock(user)">Unlock</button>
                    }
                    else
                    {
                        <button class="btn-sm btn-danger" @onclick="() => Lock(user)">Lock</button>
                    }
                    @if (_confirmDeleteId == user.Id)
                    {
                        <button class="btn-sm btn-danger" @onclick="() => DeleteUser(user)">Confirm</button>
                        <button class="btn-sm" @onclick="() => _confirmDeleteId = null">Cancel</button>
                    }
                    else
                    {
                        <button class="btn-sm btn-danger" @onclick="() => _confirmDeleteId = user.Id">Delete</button>
                    }
                </td>
            </tr>
        }
    </tbody>
</table>

<div class="pagination">
    <button class="btn-sm" disabled="@(_page <= 1)" @onclick="() => LoadPage(_page - 1)">Prev</button>
    <span>Page @_page</span>
    <button class="btn-sm" disabled="@(_users.Count < _pageSize)" @onclick="() => LoadPage(_page + 1)">Next</button>
</div>

@code {
    private List<ApplicationUser> _users = [];
    private string _search = "";
    private int _page = 1;
    private const int _pageSize = 20;
    private string _newEmail = "", _newFullName = "", _newPassword = "", _newRole = "";
    private string _message = "";
    private bool _isError;
    private Guid? _confirmDeleteId;

    protected override async Task OnInitializedAsync() => await LoadPage(1);

    private async Task LoadPage(int page)
    {
        _page = page;
        var query = UserManager.Users.AsQueryable();
        if (!string.IsNullOrEmpty(_search))
            query = query.Where(u => u.Email!.Contains(_search) || u.FullName.Contains(_search));

        _users = await query
            .OrderBy(u => u.CreatedAt)
            .Skip((_page - 1) * _pageSize)
            .Take(_pageSize)
            .ToListAsync();
    }

    private async Task CreateUser()
    {
        _message = "";
        if (string.IsNullOrWhiteSpace(_newEmail) || string.IsNullOrWhiteSpace(_newFullName) || string.IsNullOrWhiteSpace(_newPassword))
        {
            _message = "Email, Full Name and Password are required.";
            _isError = true;
            return;
        }

        var user = new ApplicationUser
        {
            UserName = _newEmail,
            Email = _newEmail,
            FullName = _newFullName,
            EmailConfirmed = true
        };

        var result = await UserManager.CreateAsync(user, _newPassword);
        if (!result.Succeeded)
        {
            _message = string.Join(" ", result.Errors.Select(e => e.Description));
            _isError = true;
            return;
        }

        if (!string.IsNullOrWhiteSpace(_newRole))
            await UserManager.AddToRoleAsync(user, _newRole);

        _message = $"User '{_newEmail}' created successfully.";
        _isError = false;
        _newEmail = ""; _newFullName = ""; _newPassword = ""; _newRole = "";
        await LoadPage(_page);
    }

    private async Task DeleteUser(ApplicationUser user)
    {
        var result = await UserManager.DeleteAsync(user);
        if (result.Succeeded)
        {
            _message = $"User '{user.Email}' deleted.";
            _isError = false;
        }
        else
        {
            _message = string.Join(" ", result.Errors.Select(e => e.Description));
            _isError = true;
        }
        _confirmDeleteId = null;
        await LoadPage(_page);
    }

    private async Task Lock(ApplicationUser user)
    {
        await UserManager.SetLockoutEndDateAsync(user, DateTimeOffset.UtcNow.AddYears(100));
        await LoadPage(_page);
    }

    private void GoToUser(Guid id) => Nav.NavigateTo($"admin/users/{id}");

    private async Task Unlock(ApplicationUser user)
    {
        await UserManager.SetLockoutEndDateAsync(user, null);
        await UserManager.ResetAccessFailedCountAsync(user);
        await LoadPage(_page);
    }
}
